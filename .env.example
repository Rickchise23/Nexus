# Anthropic (Agent Bay — /api/agent/chat)
ANTHROPIC_API_KEY=
# Optional — defaults to claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Home Assistant (server-side only — never exposed to the browser)
# When unset, Nexus uses mock devices for Home OS UI + agent tools return mock hints.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Frigate NVR — camera stats, events, snapshots (Nexus OS Cameras module)
# FRIGATE_URL=http://frigate.local:5000

# Optional — MQTT health row in System module (matches docker-compose Mosquitto)
# MQTT_URL=mqtt://127.0.0.1:1883
# MQTT_HOST=127.0.0.1

# Optional — local Ollama on the Mac Mini (future agent tools)
# OLLAMA_HOST=http://127.0.0.1:11434

# Roadmap: Clerk (auth) / Supabase — not wired in this repo yet
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Vercel — couch deploy from phone/controller + Agent tool `nexus_trigger_deploy`
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Git on the Mac mini (Launch Pad clone path). Agent tools: nexus_git_status, nexus_git_push
# NEXUS_REPO_PATH=/Users/you/Projects/launchpad
# NEXUS_GIT_PUSH_ENABLED=false
