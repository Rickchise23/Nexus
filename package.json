{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n \"next,ws\" -c \"blue,magenta\" \"next dev\" \"node src/lib/ws-server.mjs\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently -n \"next,ws\" -c \"blue,magenta\" \"next start\" \"node src/lib/ws-server.mjs\"",
    "setup": "./setup.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "check:env": "node scripts/check-env.cjs",
    "preflight": "node scripts/check-env.cjs",
    "verify": "npm run build && npx tsc --noEmit && npm run check:env && ./scripts/security-check.sh",
    "ws": "node src/lib/ws-server.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^11.0.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
